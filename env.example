# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/revenue_copilot
# Optional: direct connection for migrations (avoids "must be owner" with Supabase pooler)
# Use port 5432, not 6543; omit ?pgbouncer=true
# MIGRATION_DATABASE_URL=postgresql://postgres:password@host:5432/postgres
DB_TCP_KEEPALIVES_IDLE_SECONDS=60
DB_TCP_KEEPALIVES_INTERVAL_SECONDS=30
DB_TCP_KEEPALIVES_COUNT=5

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI (for embeddings + optional web-search fallback synthesis)
OPENAI_API_KEY=your_openai_api_key
# Optional: preferred OpenAI model for research fallback (GPT-5+ recommended; fallback chain uses GPT-5 family)
OPENAI_RESEARCH_MODEL=gpt-5

# Perplexity (for web search tool)
# Get your API key from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key

# Exa (default web search provider: semantic search, per-result excerpts)
# Get your API key: sign up at https://exa.ai/ then https://dashboard.exa.ai/api-keys
# Put the key here as EXA_API_KEY=your_key (or in .env in project root).
EXA_API_KEY=your_exa_api_key

# Nango - OAuth & credential management for integrations
# Get these from https://app.nango.dev
NANGO_SECRET_KEY=your_nango_secret_key
NANGO_PUBLIC_KEY=your_nango_public_key

# Optional: Override default Nango integration IDs
# NANGO_HUBSPOT_INTEGRATION_ID=hubspot
# NANGO_SLACK_INTEGRATION_ID=slack
# NANGO_GOOGLE_CALENDAR_INTEGRATION_ID=google-calendar
# NANGO_SALESFORCE_INTEGRATION_ID=salesforce
# NANGO_ZOOM_INTEGRATION_ID=zoom

# App
SECRET_KEY=your_secret_key_for_sessions_change_this_in_production
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
# Production: FRONTEND_URL=https://app.basebase.com

# Supabase configuration (backend)
# Get these from your Railway project variables.
# URL: Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co
# JWT Secret: Legacy HS256 secret (optional if using ES256 keys)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Admin (for waitlist management)
ADMIN_KEY=your_secret_admin_key

# Email (Resend) - for sending invitation emails
# Get your API key from https://resend.com
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=Basebase <hello@yourdomain.com>

# ScrapingBee (for fetch_url tool - web scraping with proxy support)
# Get your API key from https://www.scrapingbee.com
SCRAPINGBEE_API_KEY=your_scrapingbee_api_key

# E2B (sandboxed code execution for execute_command tool)
# Get your API key from https://e2b.dev/dashboard
E2B_API_KEY=your_e2b_api_key

# Slack (Events API + Add-to-Slack bot install)
# Signing secret from api.slack.com app → Basic Information
SLACK_SIGNING_SECRET=your_slack_signing_secret
# Same Slack app as Nango — for Add-to-Slack OAuth code exchange
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
# Public backend URL for Slack redirect_uri (e.g. https://api.basebase.com)
BACKEND_PUBLIC_URL=https://api.basebase.com

# PagerDuty (dependency outage incident creation)
PAGERDUTY_FROM_EMAIL=alerts@yourdomain.com
# API key env var supports both PAGERDUTY_KEY and PagerDuty_Key; prefer PagerDuty_Key for current deployment compatibility
PagerDuty_Key=your_pagerduty_api_key
PAGERDUTY_SERVICE_ID=your_pagerduty_service_id

# Frontend (Vite) - prefix with VITE_ so they're exposed to the client at build time
VITE_API_URL=http://localhost:8000
# Production build: VITE_API_URL=https://api.basebase.com
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_NANGO_PUBLIC_KEY=your_nango_public_key
# Optional: "Back to home" / waitlist link (default https://www.basebase.com)
# VITE_WWW_URL=https://www.basebase.com

# Credits
NUM_GRACE_CREDITS=5

# Support requests — Slack Incoming Webhook for immediate notification (optional; fallback: email to support@basebase.com)
# SUPPORT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
